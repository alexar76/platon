# Copy to /root/.gitea/credentials (chmod 600) — never commit the real file.
#
#   mkdir -p /root/.gitea
#   cp gitea.credentials.example /root/.gitea/credentials
#   # fill GITEA_TOKEN (Gitea → Settings → Applications → Generate Token)
#
GITEA_URL=http://127.0.0.1:3000
GITEA_USER=alexar76
GITEA_TOKEN=
